{% extends 'base.html.twig' %}

{% block title %}Mi perfil — TFGdaw{% endblock %}

{% block body %}
<div class="main-content">

  <div class="page-header">
    <div class="page-header__left">
      <h1 class="page-header__title">👤 Mi perfil</h1>
      <p class="page-header__subtitle">Gestiona tu información personal y preferencias</p>
    </div>
  </div>

  {% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
  {% endfor %}

  <div class="profile-layout">

    {# ── Avatar sidebar ── #}
    <div class="profile-avatar-card">
      {% if app.user.avatar %}
        <img class="profile-avatar-card__img"
             src="/uploads/avatars/{{ app.user.avatar }}"
             alt="Avatar">
      {% else %}
        <img class="profile-avatar-card__img"
             src="https://api.dicebear.com/7.x/initials/svg?seed={{ (app.user.displayName ?: app.user.email)|url_encode }}&radius=50"
             alt="Avatar">
      {% endif %}

      <div class="profile-avatar-card__name">
        {{ app.user.displayName ?: 'Sin nombre' }}
      </div>
      <div class="profile-avatar-card__email">{{ app.user.email }}</div>

      {% if app.user.bio %}
        <p class="profile-avatar-card__bio">{{ app.user.bio }}</p>
      {% else %}
        <p class="profile-avatar-card__bio" style="font-style:italic;">Sin bio todavía.</p>
      {% endif %}

      <div style="display:flex;gap:1.25rem;margin-top:.5rem;padding-top:.75rem;border-top:1px solid var(--color-border);width:100%;">
        <div style="text-align:center;flex:1;">
          <div style="font-size:1.25rem;font-weight:800;color:var(--color-primary);" id="own-followers">—</div>
          <div style="font-size:.72rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.04em;">seguidores</div>
        </div>
        <div style="text-align:center;flex:1;">
          <div style="font-size:1.25rem;font-weight:800;color:var(--color-primary);" id="own-following">—</div>
          <div style="font-size:.72rem;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.04em;">siguiendo</div>
        </div>
      </div>
    </div>

    {# ── Sections ── #}
    <div class="profile-sections">

      {# — Información personal — #}
      <div class="profile-section">
        <div class="profile-section__header">
          <span class="profile-section__icon">✏️</span>
          <span class="profile-section__title">Información personal</span>
        </div>
        <div class="profile-section__body">
          <form method="post" enctype="multipart/form-data">
            <input type="hidden" name="_action" value="profile">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
              <div class="form-group" style="margin-bottom:0;">
                <label class="form-label">Nombre visible</label>
                <input
                  type="text"
                  name="displayName"
                  class="form-control"
                  value="{{ app.user.displayName }}"
                  maxlength="80"
                  placeholder="¿Cómo quieres que te llamen?"
                >
              </div>
              <div class="form-group" style="margin-bottom:0;">
                <label class="form-label">Foto de perfil</label>
                <input type="file" name="avatar" accept="image/*" class="form-control" style="padding:6px 14px;">
                <p class="text-muted text-sm mt-1">JPG/PNG. Sustituye la foto actual.</p>
              </div>
            </div>
            <div class="form-group mt-3" style="margin-bottom:0;">
              <label class="form-label">Biografía</label>
              <textarea name="bio" class="form-control" rows="3"
                placeholder="Cuéntanos algo sobre ti y tus lecturas favoritas…">{{ app.user.bio }}</textarea>
            </div>
            <div class="mt-3">
              <button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
          </form>
        </div>
      </div>

      {# — Privacidad — #}
      <div class="profile-section">
        <div class="profile-section__header">
          <span class="profile-section__icon">🔒</span>
          <span class="profile-section__title">Privacidad</span>
        </div>
        <div class="profile-section__body">
          <p class="text-muted text-sm mb-3">Controla qué información es visible para otros usuarios.</p>

          <div class="toggle-row">
            <div>
              <div class="toggle-row__label">Cuenta privada</div>
              <div class="toggle-row__sub">Solo tus seguidores aceptados pueden ver tu perfil completo. Los demás tendrán que enviar una solicitud.</div>
            </div>
            <form method="post">
              <input type="hidden" name="_action" value="privacy">
              <input type="hidden" name="field" value="isPrivate">
              <label class="toggle">
                <input type="checkbox"
                       name="value"
                       value="1"
                       {{ app.user.private ? 'checked' : '' }}
                       onchange="this.form.submit()">
                <span class="toggle__slider"></span>
              </label>
            </form>
          </div>

          <div class="toggle-row">
            <div>
              <div class="toggle-row__label">Estanterías públicas</div>
              <div class="toggle-row__sub">Tus seguidores pueden ver tu colección de libros</div>
            </div>
            <form method="post">
              <input type="hidden" name="_action" value="privacy">
              <input type="hidden" name="field" value="shelvesPublic">
              <label class="toggle">
                <input type="checkbox"
                       name="value"
                       value="1"
                       {{ app.user.shelvesPublic ? 'checked' : '' }}
                       onchange="this.form.submit()">
                <span class="toggle__slider"></span>
              </label>
            </form>
          </div>

          <div class="toggle-row">
            <div>
              <div class="toggle-row__label">Participación en clubs pública</div>
              <div class="toggle-row__sub">Tus seguidores pueden ver a qué clubs perteneces</div>
            </div>
            <form method="post">
              <input type="hidden" name="_action" value="privacy">
              <input type="hidden" name="field" value="clubsPublic">
              <label class="toggle">
                <input type="checkbox"
                       name="value"
                       value="1"
                       {{ app.user.clubsPublic ? 'checked' : '' }}
                       onchange="this.form.submit()">
                <span class="toggle__slider"></span>
              </label>
            </form>
          </div>
        </div>
      </div>

      {# — Solicitudes de seguimiento — #}
      <div class="profile-section" id="follow-requests-section" style="display:none;">
        <div class="profile-section__header">
          <span class="profile-section__icon">👥</span>
          <span class="profile-section__title">
            Solicitudes de seguimiento
            <span id="requests-badge" class="badge badge-primary" style="margin-left:.5rem;"></span>
          </span>
        </div>
        <div class="profile-section__body" id="follow-requests-body">
          <div class="loading-state"><div class="spinner" style="width:24px;height:24px;"></div></div>
        </div>
      </div>

      {# — Cambiar contraseña — #}
      <div class="profile-section">
        <div class="profile-section__header">
          <span class="profile-section__icon">🔑</span>
          <span class="profile-section__title">Cambiar contraseña</span>
        </div>
        <div class="profile-section__body">
          <p id="pwMsg" class="text-sm mb-3" style="display:none;"></p>
          <form id="pwForm" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Contraseña actual</label>
              <input type="password" id="pwCurrent" class="form-control" placeholder="••••••••">
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Nueva contraseña</label>
              <input type="password" id="pwNew" class="form-control" placeholder="Mínimo 6 caracteres">
            </div>
            <div class="form-group" style="margin-bottom:0;">
              <label class="form-label">Confirmar contraseña</label>
              <input type="password" id="pwConfirm" class="form-control" placeholder="Repite la nueva">
            </div>
            <div style="grid-column:1/-1;">
              <button type="submit" class="btn btn-primary">Cambiar contraseña</button>
            </div>
          </form>
        </div>
      </div>

      {# — Sesión — #}
      <div class="profile-section">
        <div class="profile-section__header">
          <span class="profile-section__icon">🚪</span>
          <span class="profile-section__title">Sesión</span>
        </div>
        <div class="profile-section__body" style="display:flex;align-items:center;justify-content:space-between;gap:16px;">
          <p class="text-muted text-sm" style="margin:0;">
            Sesión activa como <strong>{{ app.user.email }}</strong>
          </p>
          <a href="{{ path('app_logout') }}" class="btn btn-danger">Cerrar sesión</a>
        </div>
      </div>

    </div>{# /profile-sections #}
  </div>{# /profile-layout #}

</div>

<script>
(function () {
  /* ── Load follower counts ── */
  fetch('/api/profile', { credentials: 'include' })
    .then(r => r.json())
    .then(data => {
      const f = document.getElementById('own-followers');
      const g = document.getElementById('own-following');
      if (f) f.textContent = data.followers ?? 0;
      if (g) g.textContent = data.following ?? 0;
    })
    .catch(() => {});

  /* ── Follow requests ── */
  function avatarUrl(u) {
    return u.avatar
      ? '/uploads/avatars/' + u.avatar
      : 'https://api.dicebear.com/7.x/initials/svg?seed=' + encodeURIComponent(u.displayName || u.email) + '&radius=50';
  }

  async function loadFollowRequests() {
    const res  = await fetch('/api/follow-requests', { credentials: 'include' });
    const list = await res.json();

    const section = document.getElementById('follow-requests-section');
    const body    = document.getElementById('follow-requests-body');
    const badge   = document.getElementById('requests-badge');

    if (!list.length) {
      section.style.display = 'none';
      return;
    }

    section.style.display = '';
    badge.textContent = list.length;

    body.innerHTML = list.map(req => `
      <div class="follow-request-item" id="freq-${req.id}">
        <a href="/usuarios/${req.user.id}" style="display:flex;align-items:center;gap:.75rem;flex:1;text-decoration:none;color:inherit;">
          <img class="user-list-item__avatar" src="${avatarUrl(req.user)}" alt="">
          <span style="font-weight:600;font-size:.9rem;">${req.user.displayName || req.user.email}</span>
        </a>
        <div style="display:flex;gap:.5rem;">
          <button class="btn btn-primary btn-sm" onclick="handleRequest(${req.id},'accept')">Aceptar</button>
          <button class="btn btn-ghost btn-sm"   onclick="handleRequest(${req.id},'decline')">Rechazar</button>
        </div>
      </div>
    `).join('');
  }

  window.handleRequest = async function(id, action) {
    const row = document.getElementById('freq-' + id);
    if (row) row.style.opacity = '.5';

    const method = action === 'accept' ? 'POST' : 'DELETE';
    const url    = action === 'accept'
      ? `/api/follow-requests/${id}/accept`
      : `/api/follow-requests/${id}`;

    await fetch(url, { method, credentials: 'include' });
    await loadFollowRequests();
  };

  loadFollowRequests();

  /* ── Password change via API ── */
  document.getElementById('pwForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg     = document.getElementById('pwMsg');
    const current = document.getElementById('pwCurrent').value;
    const pw      = document.getElementById('pwNew').value;
    const confirm = document.getElementById('pwConfirm').value;

    msg.style.display = 'block';

    if (pw.length < 6) {
      msg.style.color = 'var(--color-danger)';
      msg.textContent = 'La contraseña debe tener al menos 6 caracteres.';
      return;
    }
    if (pw !== confirm) {
      msg.style.color = 'var(--color-danger)';
      msg.textContent = 'Las contraseñas no coinciden.';
      return;
    }

    try {
      const res = await fetch('/api/profile/password', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword: current, newPassword: pw })
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        msg.style.color = 'var(--color-success)';
        msg.textContent = '✔ Contraseña actualizada correctamente.';
        document.getElementById('pwForm').reset();
      } else {
        msg.style.color = 'var(--color-danger)';
        msg.textContent = data.error || 'Error al cambiar la contraseña.';
      }
    } catch (_) {
      msg.style.color = 'var(--color-danger)';
      msg.textContent = 'Error de red.';
    }
  });
})();
</script>
{% endblock %}
